datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  student
  admin
  super_admin
}

enum StudentRole {
  user
  ambassador
  paid
  unpaid
}

enum EnrollmentType {
  institute
  self_study
}

enum QuestionDifficulty {
  easy
  medium
  hard
}

enum ContactStatus {
  new
  read
  replied
}

enum EmailTemplateCategory {
  onboarding
  engagement
  reengagement
  exam_prep
  general
}

enum EmailTemplateStatus {
  draft
  active
}

enum EmailSegment {
  new_users
  active_users
  inactive_users
  exam_prep
  all_users
}

enum EmailScheduleStatus {
  scheduled
  sent
  cancelled
}

enum JoinUsStatus {
  new
  reviewed
  replied
}

enum UploadStatus {
  completed
  processing
  failed
}

enum QuestionReportStatus {
  open
  reviewed
  resolved
}

enum FinancialStatementInputType {
  dropdown
  manual
}

enum FeedbackStatus {
  pending
  approved
}

enum SecurityActivityType {
  failed_login
  brute_force_attempt
  too_many_requests
  account_lockout
  csrf_violation
  xss_attempt
}

enum SecurityEventStatus {
  active_threat
  suspicious
  resolved
  blocked
}

enum IpBlockSource {
  auto
  admin
}

enum StreakAuditActionType {
  increment
  reset
  no_change
  first_time
  reconciliation_reset
}

enum UserBadgeType {
  week_warrior
  fortnight_fighter
  monthly_master
  centurion
}

enum BlogPostStatus {
  draft
  published
  archived
}

enum BlogAuthorType {
  admin
  guest
  student
}

enum BlogPostVisibility {
  public
  beta
}

enum BlogRevisionSaveType {
  manual_save
  publish
  status_change
  pre_restore_snapshot
  scheduled_publish
}

enum BlogAnalyticsEventType {
  page_view
  read_complete
  cta_click
  share_click
  signup_from_blog
}

enum BlogCtaPosition {
  mid_article
  end_article
}

enum BlogSharePlatform {
  whatsapp
  facebook
  copy
}

enum BlogReferrerSource {
  google
  whatsapp
  facebook
  direct
  other
}

enum InstituteSuggestionStatus {
  pending
  approved
  rejected
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  password             String
  name                 String
  role                 UserRole @default(student)
  studentRole          StudentRole @default(unpaid)
  avatar               String   @default("/avatars/boy_1.png")
  avatarId             String?  @map("avatar_id")
  isBanned             Boolean  @default(false)
  adminOtpFailedAttempts Int    @default(0)
  degree               String   @default("")
  level                String   @default("")
  enrollmentType       EnrollmentType @default(institute)
  institute            String?
  city                 String?
  studentId            String?  @unique
  cenNumber            String?  @unique
  phone                String?  @unique
  instituteRating      Int?
  termsAcceptedAt      DateTime?
  examName             String   @default("")
  examDate             DateTime?
  dailyQuestionGoal    Int      @default(0)
  prepChecklist        Json?
  practiceStreakCurrent Int     @default(0)
  practiceStreakBest    Int     @default(0)
  practiceStreakLastDate DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  financialStatementAttempts FinancialStatementAttempt[]
  userFsProgress            UserFsProgress?
  financialStatementReports FinancialStatementReport[]
  feedback                 UserFeedback?
  streakAuditLogs          StreakAuditLog[]
  badges                   UserBadge[]
  mockTestQuestionHistory  MockTestQuestionHistory[]
}

model Subject {
  id             String   @id @default(cuid())
  name           String   @unique
  code           String   @unique
  description    String?
  chapters       Json?
  totalQuestions Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Upload {
  id        String       @id @default(cuid())
  filename  String
  subject   String
  status    UploadStatus @default(processing)
  count     Int          @default(0)
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Question {
  id            String             @id @default(cuid())
  subject       String
  chapter       String?
  questionNumber Int
  question      String
  imageUrl      String?
  options       String[]
  optionImageUrls String[] @default([])
  correctAnswer Int?
  correctAnswers Int[] @default([])
  allowMultiple Boolean            @default(false)
  maxSelections Int                @default(2)
  explanation   String
  difficulty    QuestionDifficulty @default(medium)
  uploadId      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  mockTestQuestionHistory MockTestQuestionHistory[]

  @@index([subject, chapter])
}

model TestResult {
  id            String   @id @default(cuid())
  userId        String?
  subject       String
  totalQuestions Int
  correctAnswers Int      @default(0)
  wrongAnswers   Int      @default(0)
  notAttempted   Int      @default(0)
  score          Int      @default(0)
  weightedScore  Float?
  weightedTotal  Float?
  weightedPercent Float?
  passed         Boolean  @default(false)
  answers        Json?
  duration       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, subject, createdAt])
}

model BaeMockSession {
  id             String   @id @default(cuid())
  userId         String
  testType       String   @default("bae_mock")
  subjectIds     Json
  chapterBreakdown Json?  @map("chapter_breakdown")
  status         String   @default("in_progress")
  completed      Boolean  @default(false)
  totalQuestions Int
  timeAllowed    Int
  timeTaken      Int?
  vol1Count      Int
  vol2Count      Int
  vol1Correct    Int      @default(0)
  vol2Correct    Int      @default(0)
  correctAnswers Int      @default(0)
  wrongAnswers   Int      @default(0)
  notAttempted   Int      @default(0)
  scorePercent   Int      @default(0)
  questionSet    Json
  answers        Json?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, completed, createdAt])
  @@index([testType, completed, createdAt])
}

model MockTestQuestionHistory {
  id                Int      @id @default(autoincrement())
  userId            String
  questionId        String
  mockTestId        String
  answeredCorrectly Boolean
  seenAt            DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, questionId])
  @@index([userId, seenAt])
  @@unique([userId, questionId, mockTestId])
}

model MockTestNotifyRequest {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  testType  String   @map("test_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, testType])
  @@index([testType, createdAt])
  @@map("mock_test_notify_requests")
}

model Analytics {
  id               String   @id @default(cuid())
  path             String
  referrer         String?
  userAgent        String?
  screenResolution String?
  ip               String?
  userId           String?
  createdAt        DateTime @default(now())
}

model PlatformDailyStat {
  id                  String   @id @default(cuid())
  dayKey              String   @unique @map("day_key")
  timezone            String   @default("PKT")
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  userCount           Int      @default(0) @map("user_count")
  totalTests          Int      @default(0) @map("total_tests")
  totalQuestions      Int      @default(0) @map("total_questions")
  overallAccuracy     Float    @default(0) @map("overall_accuracy")
  avgQuestionsPerDay  Float    @default(0) @map("avg_questions_per_day")
  avgStreak           Float    @default(0) @map("avg_streak")
  avgTimePerQuestion  Float    @default(0) @map("avg_time_per_question")
  subjectAverages     Json     @map("subject_averages")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([periodStart])
  @@map("platform_stats_daily")
}

model UserRecommendationCache {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  rangeKey        String   @default("all") @map("range_key")
  recommendations Json
  generatedAt     DateTime @default(now()) @map("generated_at")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, rangeKey])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@map("user_recommendations")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactStatus @default(new)
  reply     String?
  replyAt   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model EmailTemplate {
  id        String               @id @default(cuid())
  name      String
  category  EmailTemplateCategory @default(general)
  subject   String
  body      String
  status    EmailTemplateStatus  @default(draft)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  schedules EmailSchedule[]
}

model EmailSchedule {
  id              String             @id @default(cuid())
  name            String
  templateId      String
  template        EmailTemplate      @relation(fields: [templateId], references: [id])
  segment         EmailSegment
  sendAt          DateTime
  status          EmailScheduleStatus @default(scheduled)
  sentAt          DateTime?
  sentCount       Int                @default(0)
  newWithinDays   Int                @default(1)
  activeWithinDays Int               @default(7)
  inactiveDays    Int                @default(14)
  examDaysBefore  Int                @default(30)
  lastError       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Flashcard {
  id        String   @id @default(cuid())
  userId    String
  subject   String?
  chapter   String?
  front     String
  back      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  subject   String?
  chapter   String?
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String   @default("super_admin")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String?
  endpoint     String   @unique
  subscription Json
  createdAt    DateTime @default(now())
}

model JoinUsRequest {
  id         String      @id @default(cuid())
  type       String
  name       String
  email      String
  phone      String?
  institute  String?
  role       String?
  experience String?
  message    String?
  status     JoinUsStatus @default(new)
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ReviewSchedule {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  stageIndex     Int      @default(0)
  correctStreak  Int      @default(0)
  totalReviews   Int      @default(0)
  nextReviewAt   DateTime
  lastReviewedAt DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, questionId])
}

model ReviewNotificationLog {
  id        String   @id @default(cuid())
  userId    String   @unique
  lastSentAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestionReport {
  id            String              @id @default(cuid())
  questionId    String
  questionText  String              @default("")
  userId        String
  email         String
  subject       String?
  questionNumber Int?
  reason        String
  status        QuestionReportStatus @default(open)
  adminReply    String?
  repliedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  minutes   Int
  focusMode String   @default("pomodoro")
  createdAt DateTime @default(now())
}

model SystemSettings {
  id                     String   @id @default(cuid())
  isMaintenanceMode      Boolean  @default(false)
  adsEnabled             Boolean  @default(true)
  welcomeMessageTemplate String   @default("Welcome back, {{name}}!")
  adContent              Json?
  testSettings           Json?
  activeAvatarPackId     String?  @map("active_avatar_pack_id")
  toggledBy              String?
  updatedAt              DateTime @updatedAt

  activeAvatarPack       AvatarPack? @relation(fields: [activeAvatarPackId], references: [id])
}

model InstituteSuggestion {
  id                String                    @id @default(cuid())
  suggestedName     String                    @map("suggested_name")
  normalizedName    String                    @unique @map("normalized_name")
  status            InstituteSuggestionStatus @default(pending)
  requestedByUserId String?                   @map("requested_by_user_id")
  requestedByEmail  String?                   @map("requested_by_email")
  requestedByName   String?                   @map("requested_by_name")
  usageCount        Int                       @default(1) @map("usage_count")
  reviewedBy        String?                   @map("reviewed_by")
  reviewNote        String?                   @map("review_note")
  reviewedAt        DateTime?                 @map("reviewed_at")
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([usageCount])
  @@map("institute_suggestions")
}

model AvatarPack {
  id            String   @id @default(cuid())
  name          String
  source        String   @default("dicebear")
  dicebearStyle String   @map("dicebear_style")
  variantsCount Int      @default(20) @map("variants_count")
  seeds         Json
  isActive      Boolean  @default(false) @map("is_active")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  activeInSettings SystemSettings[]

  @@index([isActive])
  @@index([source])
  @@index([createdAt])
  @@map("avatar_packs")
}

model FinancialStatementCase {
  id                 Int      @id @default(autoincrement())
  caseNumber         String   @unique
  title              String
  trialBalancePdfUrl String
  additionalInfo     String?
  defaultTimeLimit   Int      @default(45)
  isActive           Boolean  @default(true)
  showThousandsNote  Boolean  @default(false)
  totalMarks         Decimal  @default(20.00) @db.Decimal(5, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sociLineItems SociLineItem[]
  sofpLineItems SofpLineItem[]
  attempts     FinancialStatementAttempt[]
  reports      FinancialStatementReport[]
}

model SociLineItem {
  id             Int      @id @default(autoincrement())
  caseId         Int
  heading        String
  inputType      FinancialStatementInputType @default(dropdown)
  dropdownOptions Json
  correctValue   String
  marks          Decimal  @db.Decimal(5, 2)
  displayOrder   Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  case FinancialStatementCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([displayOrder])
}

model SofpLineItem {
  id             Int      @id @default(autoincrement())
  caseId         Int
  heading        String
  inputType      FinancialStatementInputType @default(dropdown)
  groupLabel     String?
  dropdownOptions Json
  correctValue   String
  marks          Decimal  @db.Decimal(5, 2)
  displayOrder   Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  case FinancialStatementCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([displayOrder])
}

model FinancialStatementAttempt {
  id                  Int      @id @default(autoincrement())
  userId              String
  caseId              Int
  caseNumber          String
  sociAnswers         Json
  sofpAnswers         Json
  totalMarksObtained  Decimal  @db.Decimal(5, 2)
  totalMarks          Decimal  @default(20.00) @db.Decimal(5, 2)
  percentageScore     Decimal  @db.Decimal(5, 2)
  timeSpent           Int
  timeLimitSet        Int
  startedAt           DateTime
  submittedAt         DateTime
  status              String   @default("completed")
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  case FinancialStatementCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([caseId])
  @@index([submittedAt])
}

model UserFsProgress {
  id            Int      @id @default(autoincrement())
  userId        String   @unique
  totalAttempts Int      @default(0)
  averageScore  Decimal  @default(0.00) @db.Decimal(5, 2)
  bestScore     Decimal  @default(0.00) @db.Decimal(5, 2)
  casesCompleted Json    @default("[]")
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FinancialStatementReport {
  id          String              @id @default(cuid())
  caseId      Int
  lineItemId  Int?
  section     String
  heading     String?
  caseNumber  String?
  caseTitle   String?
  userId      String
  email       String
  reason      String
  status      QuestionReportStatus @default(open)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  case FinancialStatementCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([status])
  @@index([userId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  actorRole  String
  action     String
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model IpActivityLog {
  id             String             @id @default(cuid())
  ipAddress      String             @map("ip_address")
  activityType   SecurityActivityType @map("activity_type")
  targetUserId   String?            @map("target_user_id")
  targetEndpoint String?            @map("target_endpoint")
  attemptsCount  Int                @default(1) @map("attempts_count")
  firstSeen      DateTime           @default(now()) @map("first_seen")
  lastSeen       DateTime           @default(now()) @map("last_seen")
  status         SecurityEventStatus @default(suspicious)
  isReviewed     Boolean            @default(false) @map("is_reviewed")
  reviewedAt     DateTime?          @map("reviewed_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([ipAddress])
  @@index([createdAt])
  @@index([status])
  @@index([activityType, createdAt])
  @@map("ip_activity_log")
}

model BlockedIp {
  id                      String        @id @default(cuid())
  ipAddress               String        @unique @map("ip_address")
  reason                  String
  blockedBy               String        @map("blocked_by")
  blockedAt               DateTime      @default(now()) @map("blocked_at")
  isActive                Boolean       @default(true) @map("is_active")
  blockSource             IpBlockSource @default(admin) @map("block_source")
  totalAttemptsBeforeBlock Int          @default(0) @map("total_attempts_before_block")
  isSubnet                Boolean       @default(false) @map("is_subnet")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  @@index([ipAddress])
  @@index([blockedAt])
  @@index([isActive, blockedAt])
  @@index([createdAt])
  @@map("blocked_ips")
}

model WhitelistedIp {
  id        String   @id @default(cuid())
  ipAddress String   @unique @map("ip_address")
  label     String?
  addedBy   String   @map("added_by")
  addedAt   DateTime @default(now()) @map("added_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ipAddress])
  @@index([addedAt])
  @@index([createdAt])
  @@map("whitelisted_ips")
}

model IpSecurityAudit {
  id          String   @id @default(cuid())
  adminId     String   @map("admin_id")
  action      String
  ipAddress   String   @map("ip_address")
  reason      String?
  performedAt DateTime @default(now()) @map("performed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  metadata    Json?

  @@index([ipAddress])
  @@index([performedAt])
  @@index([adminId, performedAt])
  @@index([createdAt])
  @@map("ip_security_audit")
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String   @unique
  rating    Int
  message   String
  status    FeedbackStatus @default(pending)
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status, createdAt])
}

model StreakAuditLog {
  id          String                @id @default(cuid())
  userId      String                @map("user_id")
  endpoint    String
  creditedDate DateTime             @map("credited_date")
  credited    Boolean
  actionType  StreakAuditActionType @map("action_type")
  streakBefore Int                  @default(0) @map("streak_before")
  streakAfter Int                   @default(0) @map("streak_after")
  createdAt   DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, creditedDate])
  @@index([createdAt])
  @@index([actionType, createdAt])
  @@map("streak_audit_log")
}

model UserBadge {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  badgeType UserBadgeType @map("badge_type")
  earnedAt  DateTime      @default(now()) @map("earned_at")
  seen      Boolean       @default(false)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
  @@index([seen, createdAt])
  @@map("user_badges")
}

model BlogAuthor {
  id          String     @id @default(cuid())
  name        String
  bio         String?
  avatarUrl   String?    @map("avatar_url")
  designation String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  posts       BlogPost[]

  @@index([createdAt])
  @@map("blog_authors")
}

model BlogCategory {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  color       String     @default("#16a34a")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  posts       BlogPost[]

  @@index([createdAt])
  @@map("blog_categories")
}

model BlogPost {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  excerpt         String         @db.VarChar(300)
  content         String
  coverImageUrl   String?        @map("cover_image_url")
  authorId        String         @map("author_id")
  authorType      BlogAuthorType @default(admin) @map("author_type")
  categoryId      String         @map("category_id")
  tags            Json?
  relatedSubjects Json?          @map("related_subjects")
  status          BlogPostStatus @default(draft)
  visibility      BlogPostVisibility @default(beta)
  featured        Boolean        @default(false)
  readingTime     Int            @default(1) @map("reading_time")
  viewsCount      Int            @default(0) @map("views_count")
  metaTitle       String?        @map("meta_title")
  metaDescription String?        @map("meta_description")
  publishedAt     DateTime?      @map("published_at")
  scheduledAt     DateTime?      @map("scheduled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  author          BlogAuthor     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category        BlogCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  revisions       BlogRevision[]
  ctaClicks       BlogCtaClick[]
  analyticsEvents BlogAnalyticsEvent[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([featured])
  @@index([visibility])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("blog_posts")
}

model BlogRevision {
  id             String               @id @default(cuid())
  postId         String               @map("post_id")
  title          String
  content        String
  excerpt        String               @db.VarChar(300)
  coverImageUrl  String?              @map("cover_image_url")
  savedBy        String               @map("saved_by")
  saveType       BlogRevisionSaveType @map("save_type")
  revisionNumber Int                  @map("revision_number")
  wordCount      Int                  @default(0) @map("word_count")
  createdAt      DateTime             @default(now()) @map("created_at")

  post           BlogPost             @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@unique([postId, revisionNumber])
  @@map("blog_revisions")
}

model BlogCtaClick {
  id          String          @id @default(cuid())
  postId      String          @map("post_id")
  subjectCode String          @map("subject_code")
  ctaPosition BlogCtaPosition @map("cta_position")
  clickedAt   DateTime        @default(now()) @map("clicked_at")
  userId      String?         @map("user_id")
  sessionId   String          @map("session_id")

  post        BlogPost        @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([subjectCode])
  @@index([clickedAt])
  @@index([sessionId])
  @@map("blog_cta_clicks")
}

model BlogAnalyticsEvent {
  id             String                @id @default(cuid())
  postId         String?               @map("post_id")
  eventType      BlogAnalyticsEventType @map("event_type")
  subjectCode    String?               @map("subject_code")
  ctaPosition    BlogCtaPosition?      @map("cta_position")
  sharePlatform  BlogSharePlatform?    @map("share_platform")
  userId         String?               @map("user_id")
  sessionId      String                @map("session_id")
  referrerSource BlogReferrerSource    @default(other) @map("referrer_source")
  timeOnPage     Int?                  @map("time_on_page")
  scrollDepth    Int?                  @map("scroll_depth")
  createdAt      DateTime              @default(now()) @map("created_at")

  post           BlogPost?             @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([eventType])
  @@index([createdAt])
  @@index([sessionId])
  @@index([postId, createdAt])
  @@map("blog_analytics_events")
}
